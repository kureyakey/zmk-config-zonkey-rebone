// ... (上部の include 等はそのまま)

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &default_layout;
        zephyr,display = &oled;
    };

    // kscan0 等の定義...
    kscan0: kscan0 { ... };

    // 追加したコンポーネント（ルート直下）
    encoder_3: encoder_3 {
        compatible = "alps,ec11";
        a-gpios = <&gpio1 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio1 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "okay";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder_3>;
        triggers-per-rotation = <20>;
    };
};

// 既存の &default_transform 等
&default_transform {
    col-offset = <6>;
};

// SPI1の設定
&spi1 {
    status = "okay";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";
    compatible = "nordic,nrf-spim";

    trackball: pd@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        // ... (以下略)
    };
};

// 下記はルートの外側に独立したブロックとして置くか、
// 必要であればルートノード内に入れる必要があります
&trackball_split {
    device = <&trackball>;
};

&trackball_listener {
    status = "okay";
    input-processors = <&zip_temp_layer 1 400>;
    scroll {
        layers = <2>;
        input-processors = <&zip_xy_transform (INPUT_TRANSFORM_Y_INVERT)>, <&zip_xy_scaler 1 16>, <&zip_xy_to_scroll_mapper>;
    };
};

// pinctrl 等の定義...
