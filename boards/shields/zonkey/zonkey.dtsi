#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,physical-layout = &zonkey_physical_layout;
        zmk,battery = &non_lipo_battery;
    };

    zonkey_physical_layout: zonkey_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys = <&key_physical_attrs 100 100 0 0 0 0 0>
             , <&key_physical_attrs 100 100 100 0 0 0 0>
             /* ... (以下略) ... */
             ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)     RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)     RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)     RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
                    RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)     RC(3,6) RC(3,7)                 RC(3,10)
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-charlieplex";
        label = "KSCAN";
    };

    /* エンコーダーやセンサーなどのノードはそのままここに配置 */
    left_encoder_1: left_encoder_1 {
        compatible = "alps,ec11";
        /* ... */
    };
    /* ... (他のノードもここに記述) ... */
}; // これでファイル全体を閉じる

&adc {
    status = "okay";
};

&spi0 {
    status = "disabled";
    trackball: trackball@0 {
        status = "disabled";
        reg = <0>;
    };
};
